set shell := ["bash", "-c"]

BIN := "dist-tx"

default := "build"

install-proto:
    go install google.golang.org/protobuf/cmd/protoc-gen-go@v1.36.11
    go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@v1.6.1

proto:
    rm -rf pb/*
    protoc --proto_path=proto \
           --go_out=pb \
           --go_opt=paths=source_relative \
           --go-grpc_out=pb \
           --go-grpc_opt=paths=source_relative \
           transaction.proto

build:
    go build -o {{BIN}} .

run-coordinator:
    ./{{BIN}} -mode=coordinator -db=coordinator.db

run-inventory:
    ./{{BIN}} -mode=inventory -db=inventory.db -seed

run-payment:
    ./{{BIN}} -mode=payment -db=payment.db -seed

run-participants: build
    ./{{BIN}} -mode=inventory -db=inventory.db -seed &
    ./{{BIN}} -mode=payment -db=payment.db -seed &

run-all: build
    ./{{BIN}} -mode=coordinator -db=coordinator.db &
    ./{{BIN}} -mode=inventory -db=inventory.db -seed &
    ./{{BIN}} -mode=payment -db=payment.db -seed &

run-client:
    ./{{BIN}} -mode=client -coordinator-addr=localhost:50051 -tps=50 -duration=60s

run-benchmark:
    ./{{BIN}} -mode=client -tps=100 -duration=30s -warmup=5s

clean-data:
    rm -f *.db

lint:
    golangci-lint run ./...

fmt:
    go fmt ./...

test:
    go test ./...

stop-all:
    pkill -f "{{BIN}}" || true
